{% if inventory_hostname != mysql_host -%}
0 2 * * 0-6  backup  mysqldump agama > /home/backup/mysql/agama.sql
30 2 * * 0  backup  duplicity --no-encryption full /home/backup/mysql/ rsync://{{ github_username }}@backup.{{ domain_name }}//home/{{ github_username }}/
30 2 * * 1-5  backup  duplicity --no-encryption incremental /home/backup/mysql/ rsync://{{ github_username }}@backup.{{ domain_name }}//home/{{ github_username }}/
{% endif -%}