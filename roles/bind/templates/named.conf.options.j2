acl lan {
	 {% for n in acl_ips %}
	 {{ n }};
	 {% endfor %}
};
options {
	directory "/var/lib/bind";

	forwarders {
		{% for n in dns_forwarders %}
		{{ n }};
		{% endfor %}
	};

    allow-query {
		lan;
	};

	dnssec-validation no;
};

statiscs-channels {
	inet 127.0.0.1 port 8053 allow { 127.0.0.1; }
};
